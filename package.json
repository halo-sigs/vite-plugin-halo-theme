{
  "name": "@halo-dev/vite-plugin-halo-theme",
  "version": "1.0.1",
  "description": "A Vite plugin for Halo theme that provides HTML template pre-compilation and multi-page entry support.",
  "keywords": [
    "halo",
    "halo-theme",
    "vite",
    "vite-plugin"
  ],
  "bugs": {
    "url": "https://github.com/halo-sigs/vite-plugin-halo-theme/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Halo",
    "url": "https://github.com/halo-dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/halo-sigs/vite-plugin-halo-theme.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vp pack",
    "prepack": "pnpm build",
    "test": "vp test run",
    "test:watch": "vp test",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "prepare": "vp config",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.22.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "typescript": "^5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "compatiblePackages": {
    "schemaVersion": 1,
    "rolldown": {
      "type": "incompatible",
      "reason": "Uses Vite-specific APIs"
    },
    "rollup": {
      "type": "incompatible",
      "reason": "Uses Vite-specific APIs"
    }
  }
}
